{
    "admin_channel_id": [
        "<CHANNEL_ID_FOR_GENERAL_ADMIN_COMMANDS>"
    ],
    "log_dir": "./logs/",
    "log_options": {
        "default_op": {
            "level": 1,
            "die": 0,
            "echo": 1
        },
        "level_register": [
            1,
            2,
            3,
            4,
            5
        ]
    },
    "heartbeat": 1800,
    "discordOptions": {
        "name": "<NAME_OF_BOT>",
        "bot_id": "<BOT_APPLICATION_ID>",
        "token": "<TOKEN_APP>",
        "icon": "<ICON_URL>",
        "description": "<DESCRIPTION_BOT>",
        "sendCommandsAPI": true
    },
    "db": {
        "host": "<HOST_DB>",
        "user": "<USER_DB>",
        "pass": "<PWD_DB>",
        "db_name": "<DBNAME_DB>"
    }
}